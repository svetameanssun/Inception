[www]

user = www-data
group = www-data
listen = 9000
#listen.owner = www-data
#listen.group = www-data
#listen.mode = 0660

pm = dynamic
pm.max_children = 5 #maximum PHP processes running simultaniously
pm.start_servers = 2 #Processes started when PHP-FPM boots
pm.min_spare_servers = 1 #Minimum idle processes kept ready
pm.max_spare_servers = 3 #Maximum idle processes allowed